# Copy to dapp/.env to point the dApp at a network.
#
# Local network (default if unset):
# AZTEC_NODE_URL=http://localhost:8080
#
# Aztec public testnet (node runs aztec 4.3.1, matches this repo):
AZTEC_NODE_URL=https://rpc.testnet.aztec-labs.com
#
# Optional: a pre-deployed AZNS address to connect to. If unset, use the
# dApp's "Deploy AZNS" button (or `npm run deploy:testnet` at the repo root,
# which writes this file for you).
# AZNS_ADDRESS=0x...
#
# Fee settlement. Used by `npm run deploy:testnet`; the dApp also reads
# PAY_TOKEN_ADDRESS as a fallback for the contract's payment_token() view.
#   PAY_TOKEN_ADDRESS  the token AZNS charges fees in. Unset => the deploy script
#                      deploys a fresh 18-decimal TEST token (operator = minter).
#                      Set to a real USD-pegged stablecoin for mainnet.
#   TREASURY_ADDRESS   where fees go (default: the deployer account).
#   UNIT_PER_CENT      USD-cents -> token base-units (default 1e16 = 1 cent for
#                      an 18-decimal USD token, so the flat $21/yr = 21 tokens).
# PAY_TOKEN_ADDRESS=0x...
# TREASURY_ADDRESS=0x...
# UNIT_PER_CENT=10000000000000000
#
# WALLET MODEL: each visitor's browser generates and self-custodies its own
# account key (localStorage). The app NEVER embeds a shared/funded secret — the
# old DAPP_WALLET_SECRET demo path has been removed. Gas is paid from the user's
# own native fee juice, or sponsored by the canonical SponsoredFPC (which the
# operator funds); the user supplies the registration token from their wallet.
