# dependencies (root node_modules is a symlink into the WSL filesystem)
node_modules

# generated contract artifacts (rebuild: aztec compile + npm run codegen)
azns/target/
faucet/target/
personhood/target/
dapp/src/contracts/
dapp/public/assets/
dapp/public/zkp_data.json

# local runtime state
pxe_data_*/
wallet_data_*/
codegenCache.json

# scratch
_*.sh
_*.out
*.log
demo_out.txt

# claude runtime
.claude/scheduled_tasks.lock

# deployer secret
scripts/.deployer.json

# local WSL run helpers (env-specific, may contain spent faucet claims)
run_*.sh
_*.sh
# ...except the full redeploy orchestrator: no secrets, worth versioning (it
# does hardcode this machine's WSL mount path - adjust when running elsewhere).
# The _1/_2 partial runners stay ignored (they pin stale per-run addresses).
!run_redeploy_full.sh

# machine-specific dApp helpers + preview launcher
*_dapp.sh
.claude/launch.json

# dApp local env (may hold the demo house-wallet secret)
dapp/.env

# beacon build artifacts (compiled like azns/faucet targets)
beacon/target/

# stealth feasibility spike build artifacts (source is versioned, target isn't)
stealth_spike/target/
